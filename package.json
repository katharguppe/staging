{
  "name": "saas-auth",
  "version": "1.0.0",
  "description": "SaaS Multi-Tenant Login Component - Monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup:keys": "node scripts/generate-keys.js",
    "dev": "npm run dev --workspace=packages/auth-bff",
    "dev:ui": "npm run dev --workspace=packages/login-ui",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "lint": "npm run lint --workspaces",
    "db:migrate": "npm run db:migrate --workspace=packages/auth-bff",
    "db:seed": "npm run db:seed --workspace=packages/auth-bff",
    "db:studio": "npm run db:studio --workspace=packages/auth-bff",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "verify": "node verify-checkpoint-02.js",
    "verify:full": "npm run docker:up && npm run db:seed && npm run verify"
  },
  "devDependencies": {
    "terser": "^5.46.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "author": "SaaS Platform Team",
  "license": "UNLICENSED"
}
